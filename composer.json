{
    "name": "ydah/php-pico",
    "type": "library",
    "description": "A compact PHP 8.3 subset runtime in C99 for POSIX and RP2040",
    "keywords": [
        "php",
        "runtime",
        "interpreter",
        "bytecode",
        "embedded",
        "rp2040"
    ],
    "homepage": "https://github.com/ydah/php-pico",
    "license": "MIT",
    "authors": [
        {
            "name": "ydah",
            "homepage": "https://github.com/ydah"
        }
    ],
    "support": {
        "issues": "https://github.com/ydah/php-pico/issues",
        "source": "https://github.com/ydah/php-pico"
    },
    "require": {
        "php": ">=7.4"
    },
    "bin": [
        "bin/php-pico"
    ],
    "archive": {
        "exclude": [
            "/.github",
            "/build",
            "/tests",
            "/third_party",
            "/*.md",
            "!/CHANGELOG.md",
            "!/README.md",
            "**/.DS_Store"
        ]
    }
}
